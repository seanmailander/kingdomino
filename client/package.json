{
  "name": "kingdomino-client",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "lint": "oxlint src",
    "start": "vite",
    "start-host": "vite --host kingdomino.local --port 80",
    "start-secure": "HTTPS=true HOST=:: PORT=443 SSL_CRT_FILE=./.cert/cert.pem SSL_KEY_FILE=./.cert/key.pem vite",
    "build": "vite build --outDir build",
    "preview": "vite preview --host",
    "test": "vitest run",
    "tscheck": "tsc --noEmit",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "alien-signals": "^3.1.2",
    "classnames": "^2.5.1",
    "event-iterator": "^2.0.0",
    "eventemitter3": "^5.0.1",
    "peerjs": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "seedrandom": "^3.0.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.0",
    "jest-extended": "^4.0.2",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.16.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
